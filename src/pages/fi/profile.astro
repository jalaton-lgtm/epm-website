---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoSlot from '../../components/PhotoSlot.astro';

// HUOM — luonnosteksti, katso avoimet kohdat profile.astro:n kommentista
// (syntymävuosi, seura, kotikaupunki).

const stats = [
  { label: 'HE · 100m', value: '14.08', unit: 's', accent: true },
  { label: 'LUOKKA', value: 'T54', unit: '' },
  { label: 'KANSALLISUUS', value: 'FIN', unit: '' },
  { label: 'HANDLE', value: '@mattilae', unit: '' },
];
---

<BaseLayout title="Profiili" lang="fi" description="Esa-Pekka Mattila — urheilijaprofiili, tulokset ja tausta.">
  <section class="profile-hero">
    <div class="wrap">
      <p class="kicker">Profiili</p>
      <h1>Esa-Pekka Mattila</h1>
    </div>
  </section>

  <section class="profile-body">
    <div class="wrap profile-grid">
      <div class="profile-photo reveal">
        <PhotoSlot placeholder="LISÄÄ MUOTOKUVA" aspect="4/5" />
      </div>
      <div class="bio reveal">
        <p class="lead">
          T54-luokan pyörätuolikelaaja, kilpailee MM- ja
          paralympiatasolla.
        </p>
        <div class="rule-accent"></div>
        <p>
          Esa-Pekka Mattila kilpailee pyörätuolikelauksessa, luokka T54,
          MM- ja paralympiatasolla. Henkilökohtainen ennätys 100
          metrillä on 14,08 sekuntia. Valmentajana toimii Leo-Pekka
          Tähti.
        </p>
        <p>
          Kilpaurheilun ohella hän toimii suomalaisen olympia- ja
          yleisurheiluhallinnon luottamustehtävissä, mukaan lukien
          Suomen Olympiakomitean Urheilijavaliokunta, sekä kahden
          Abilis-järjestön hallituksen jäsenenä.
        </p>
        <p>
          Hän toimii konsultoivana asiantuntijana pyörätuoliteknologian
          kehitystyössä, mukaan lukien aiempi yhteistyö Huawein kanssa
          puettavan teknologian kehityksessä.
        </p>

        <div class="statgrid">
          {stats.map((s) => (
            <div class="stat-block">
              <div class="k mono">{s.label}</div>
              <div class={`stat-value ${s.accent ? 'accent-text' : ''}`}>{s.value}{s.unit}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="roles">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">02</span><h2>Roolit</h2></div>
      <ul class="role-list reveal">
        <li>Urheilija — T54, 100m, MM- / paralympiataso</li>
        <li>Suomen Olympiakomitean Urheilijavaliokunta</li>
        <li>Hallituksen jäsen, Abilis (2 hallitusta)</li>
        <li>Teknologia-alan konsultti</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-hero {
    padding-top: clamp(140px, 20vh, 200px);
    padding-bottom: var(--space-4);
  }
  .profile-hero h1 {
    margin-top: var(--space-2);
  }
  .accent-text {
    color: var(--accent);
  }
  .profile-body {
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(32px, 6vw, 84px);
    align-items: start;
  }
  .bio p {
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    margin-bottom: var(--space-2);
    max-width: 36rem;
  }
  .bio p.lead {
    font-size: var(--text-lead);
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: none;
  }
  .bio .rule-accent {
    margin: var(--space-3) 0;
  }
  .statgrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    margin-top: var(--space-3);
    max-width: 28rem;
  }
  .stat-block {
    background: var(--bg);
    padding: 20px 20px 18px;
  }
  .roles {
    border-top: 1px solid var(--rule);
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: var(--space-3);
  }
  .sec-head .idx {
    color: var(--accent);
    font-size: 0.75rem;
  }
  .role-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: var(--maxw);
  }
  .role-list li {
    padding: var(--space-1) 0 var(--space-1) var(--space-2);
    border-left: 2px solid var(--accent);
  }

  @media (max-width: 860px) {
    .profile-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .statgrid { grid-template-columns: 1fr; }
  }
</style>
