---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Suomennos on Claude-luonnos EP:n rekisterissä — EP tarkistaa ennen
// julkaisua, kuten fi/profile.astro. Sovitettu suoraan englanninkielisestä
// partners.astro-sivusta (EP:n oma editointikierros), ei toimintasuunnitelman
// liitteestä A, joka on vanhentunut. Luvut vastaavat englanninkielistä sivua:
// 20 000 € kausi, 13 milj. katselukertaa (7,7 YouTube + 5,7 Facebook),
// KY:n yli 500 000 euron budjetti. Osioiden ankkurit pidetään englanniksi
// (#speaking), koska sivuston polkukäytäntö on englanninkielinen myös
// suomeksi (/fi/profile, ei /fi/profiili).
//
// HUOM: Huawein hyväksyntä lopullisiin muotoiluihin on yhä kesken, ja se
// koskee tätä sivua samalla tavalla kuin englanninkielistä.
---

<BaseLayout
  title="Kumppanit"
  lang="fi"
  description="Kumppanuudet, puheenvuorot ja asiantuntijatyö Esa-Pekka Mattilan kanssa LA 2028 -kisoihin asti. Mitä kumppanuus tarkoittaa ja mitä kausi maksaa."
>
  <section class="partners-hero">
    <div class="wrap">
      <p class="kicker">Kumppanit</p>
      <h1>Kumppanuudet,<br />puheenvuorot,<br />asiantuntijatyö<span class="accent-text">.</span></h1>
      <p class="lead">
        Olen avoin kumppanuuksille LA 2028&nbsp;-kisoihin asti. Tällä sivulla
        kerron, mitä se käytännössä tarkoittaa ja mitä se maksaa, jotta
        keskustelu voi alkaa konkretiasta.
      </p>
    </div>
  </section>

  <section class="narrative" id="partnership">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">01</span><h2>Kumppanuudet</h2></div>
      <div class="prose reveal">
        <p>
          Kausi maailman huipulla maksaa noin 20 000 euroa ennen
          elinkustannuksia: kilpapyörätuolit, harjoitusleirit, lennot,
          fysioterapia, kilpailujen osallistumismaksut, kuluva ja
          uusittava välineistö sekä muut kulut, kuten valmennus ja
          asiantuntija-apu. Kilpailusuunnitelmani kulkee Taškentin
          MM-kisoista kesäkuussa 2027 vuoden 2028 EM-kisojen kautta Los
          Angelesiin 2028, joka on urani viimeinen huipentuma.
        </p>
        <p>
          Omat kanavani ovat pienet, enkä väitä muuta. Ne ovat myös
          kumppanin käytössä, mutta tavoittavuus ei synny niistä. Minä
          tuon sisällön: kaksikymmentä vuotta kilpailua maailman
          huipulla, sen rinnalla kulkeneen hallintouran ja näytöt siitä,
          että puhun kameran edessä totta. Kumppani tuo jakelun. Kun
          Huawei kuvasi yhteistyömme puettavan teknologian parissa,
          Wheels of Change keräsi yli 13 miljoonaa katselukertaa, <a
          href="https://www.youtube.com/watch?v=zKV9IRRmU3U"
          target="_blank" rel="noopener">7,7 miljoonaa YouTubessa</a> ja
          <a
          href="https://www.facebook.com/huawei/videos/wheels-of-change/1425655212392731/"
          target="_blank" rel="noopener">5,7 miljoonaa Facebookissa</a>,
          heidän kanavillaan eikä minun. Tätä työnjakoa ehdotan, ja se on
          toiminut jo kerran.
        </p>
        <p>
          Ehdoista sovitaan tapauskohtaisesti. Etsin pientä joukkoa
          merkityksellisiä kumppaneita, en paitaa täynnä logoja.
        </p>
      </div>
    </div>
  </section>

  <section class="narrative" id="speaking">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">02</span><h2>Puheenvuorot</h2></div>
      <div class="prose reveal">
        <p>
          Puheenvuoroja, paneeleja ja työpajoja suomeksi ja englanniksi.
        </p>
        <p>
          Urheilijoiden edustusta siellä, missä sillä on oikeasti
          merkitystä: valintaprosessit, rahoituksesta syntyvät
          erimielisyydet ja eri suuntiin vetävien tahojen
          yhteensovittaminen. Lajiliitto ei voi olla samaan aikaan
          urheilijoiden edustaja niissä huoneissa, miten se sitten
          muotoillaankin. Vammaisinkluusio samalla otteella. Kummassakin
          ongelman nimeäminen on helpompi puoli; työ on sen rakentamista,
          mikä ongelman ratkaisee.
        </p>
        <p>
          Näiden rinnalla: päätöksenteko rajallisten resurssien
          puitteissa ja se, mitä huippu-urheilun järjestelmät voivat
          opettaa tavalliselle työelämälle ja liiketoiminnalle.
        </p>
      </div>
    </div>
  </section>

  <section class="narrative" id="advisory">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">03</span><h2>Asiantuntijatyö</h2></div>
      <div class="prose reveal">
        <p>
          Asiantuntijatyötä pyörätuoli- ja apuvälineteknologian parissa,
          esimerkiksi Huawein kanssa, jossa tuoteominaisuus kulki
          urheilijan palautteesta julkaistuun versioon asti. Lisäksi
          saavutettavuus- ja hallintokysymykset, joissa eletty kokemus,
          hallituskokemus ja yritysjuridiikan tausta yhdistyvät. Aiemmin
          toimin Aalto-yliopiston kauppatieteiden ylioppilaiden (KY)
          pääsihteerinä, jossa vuosibudjetti oli yli 500 000 euroa, ja
          sieltä operatiivinen ymmärrys on peräisin.
        </p>
        <p>
          Aina avoinna, sparrauksesta selkeästi rajattuun projektiin.
        </p>
      </div>
    </div>
  </section>

  <section class="partners-cta">
    <div class="wrap">
      <div class="rule-accent"></div>
      <p class="cta-line">Kiinnostuitko?</p>
      <a href="mailto:ep@esapekkamattila.com" class="cta-mail">ep@esapekkamattila.com</a>
    </div>
  </section>
</BaseLayout>

<style>
  .partners-hero {
    padding-top: clamp(140px, 20vh, 200px);
    padding-bottom: var(--space-5);
  }
  .partners-hero h1 {
    margin-top: var(--space-2);
  }
  .accent-text {
    color: var(--accent);
  }
  .partners-hero .lead {
    margin-top: var(--space-4);
    font-size: var(--text-lead);
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: 32rem;
  }

  .narrative {
    border-top: 1px solid var(--rule);
    /* Clears the fixed nav when arriving via /fi/partners#speaking */
    scroll-margin-top: 90px;
  }
  .narrative .prose p {
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    margin-bottom: var(--space-2);
    max-width: 44rem;
  }
  .narrative .prose p:last-child {
    margin-bottom: 0;
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: var(--space-3);
  }
  .sec-head .idx {
    color: var(--accent);
    font-size: 0.75rem;
  }

  .partners-cta {
    border-top: 1px solid var(--rule);
  }
  .cta-line {
    margin-top: var(--space-3);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-h2);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: var(--line-tight);
  }
  .cta-mail {
    display: inline-block;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.06em;
  }
</style>
