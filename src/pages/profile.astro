---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoSlot from '../components/PhotoSlot.astro';

// NOTE — draft copy, written in your usual register (factual, no
// motivational language). Review before publishing.
//
// Confirmed by EP: born 1989, club Espoon Tapiot (espoontapiot.fi),
// home city Espoo (resolves the earlier Espoo-vs-elsewhere discrepancy
// in the brand file in favor of Espoo). Photos still pending — added
// in a follow-up once EP sends them.

const stats = [
  { label: 'PB · 100M', value: '14.08', unit: 's', accent: true },
  { label: 'CLASSIFICATION', value: 'T54', unit: '' },
  { label: 'NATIONALITY', value: 'FIN', unit: '' },
  { label: 'HANDLE', value: '@mattilae', unit: '' },
  { label: 'CLUB', value: 'Espoon Tapiot', unit: '', href: 'https://espoontapiot.fi/' },
  { label: 'BASED', value: 'Espoo, FIN', unit: '' },
];
---

<BaseLayout title="Profile" lang="en" description="Esa-Pekka Mattila — athlete profile, results, and background.">
  <section class="profile-hero">
    <div class="wrap">
      <p class="kicker">Profile</p>
      <h1>Esa-Pekka Mattila</h1>
    </div>
  </section>

  <section class="profile-body">
    <div class="wrap profile-grid">
      <div class="profile-photo reveal">
        <PhotoSlot src="/images/portrait.jpg" alt="Esa-Pekka Mattila" placeholder="DROP A PORTRAIT" aspect="4/5" />
      </div>
      <div class="bio reveal">
        <p class="lead">
          T54 wheelchair racer competing at World Championship and
          Paralympic level.
        </p>
        <div class="rule-accent"></div>
        <p>
          Esa-Pekka Mattila (b. 1989) competes in wheelchair racing,
          classification T54, at World Championship and Paralympic
          level. Based in Espoo, Finland, racing for Espoon Tapiot. His
          personal best over 100m is 14.08 seconds. He trains under
          coach Leo-Pekka Tähti.
        </p>
        <p>
          Alongside competing, he holds governance roles within Finnish
          Olympic and athletics administration, including a seat on the
          Athletes' Commission of the Finnish Olympic Committee, and
          serves on two boards within the Abilis organisation.
        </p>
        <p>
          He works as an advisor on wheelchair-related technology
          development, including past work with Huawei on wearable
          technology.
        </p>

        <div class="statgrid">
          {stats.map((s) => (
            <div class="stat-block">
              <div class="k mono">{s.label}</div>
              <div class={`stat-value ${s.accent ? 'accent-text' : ''}`}>
                {s.href ? <a href={s.href} target="_blank" rel="noopener">{s.value}{s.unit}</a> : `${s.value}${s.unit}`}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="roles">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">02</span><h2>Roles</h2></div>
      <ul class="role-list reveal">
        <li>Athlete — T54 100m, World Championship / Paralympic level</li>
        <li>Athletes' Commission, Finnish Olympic Committee</li>
        <li>Board member, Abilis (×2 boards)</li>
        <li>Technology advisor / consultant</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-hero {
    padding-top: clamp(140px, 20vh, 200px);
    padding-bottom: var(--space-4);
  }
  .profile-hero h1 {
    margin-top: var(--space-2);
  }
  .accent-text {
    color: var(--accent);
  }
  .profile-body {
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(32px, 6vw, 84px);
    align-items: start;
  }
  .bio p {
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    margin-bottom: var(--space-2);
    max-width: 36rem;
  }
  .bio p.lead {
    font-size: var(--text-lead);
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: none;
  }
  .bio .rule-accent {
    margin: var(--space-3) 0;
  }
  .statgrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    margin-top: var(--space-3);
    max-width: 28rem;
  }
  .stat-block {
    background: var(--bg);
    padding: 20px 20px 18px;
  }
  .roles {
    border-top: 1px solid var(--rule);
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: var(--space-3);
  }
  .sec-head .idx {
    color: var(--accent);
    font-size: 0.75rem;
  }
  .role-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: var(--maxw);
  }
  .role-list li {
    padding: var(--space-1) 0 var(--space-1) var(--space-2);
    border-left: 2px solid var(--accent);
  }

  @media (max-width: 860px) {
    .profile-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .statgrid { grid-template-columns: 1fr; }
  }
</style>
