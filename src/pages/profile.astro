---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoSlot from '../components/PhotoSlot.astro';

// Copy confirmed by EP (July 2026): first person site-wide, chair of the
// NOC Athletes' Commission + NOC board seat, NPC Athletes' Commission
// chaired until autumn 2024, board seats named per EP's list. "Finnish
// Athletics Athletes" association deliberately omitted (dormant).

const stats = [
  { label: 'PB · 100M', value: '14.08', unit: 's', accent: true },
  { label: 'CLASSIFICATION', value: 'T54', unit: '' },
  { label: 'BORN', value: '1989', unit: '' },
  { label: 'HANDLE', value: '@mattilae', unit: '' },
  { label: 'CLUB', value: 'Espoon Tapiot', unit: '', href: 'https://espoontapiot.fi/' },
  { label: 'BASED', value: 'Espoo, FIN', unit: '' },
];
---

<BaseLayout title="Profile" lang="en" description="Esa-Pekka Mattila: T54 wheelchair racer and sports governance professional. Career, roles, and background.">
  <section class="profile-hero">
    <div class="wrap">
      <p class="kicker">Profile</p>
      <h1>Esa-Pekka Mattila</h1>
    </div>
  </section>

  <section class="profile-body">
    <div class="wrap profile-grid">
      <div class="profile-photo reveal">
        <PhotoSlot src="/images/portrait.jpg" alt="Esa-Pekka Mattila" placeholder="DROP A PORTRAIT" aspect="4/5" />
      </div>
      <div class="bio reveal">
        <p class="lead">
          Para-athlete and sports governance professional.
        </p>
        <div class="rule-accent"></div>
        <p>
          Twenty years of international T54 wheelchair racing, alongside
          board-level roles across Finnish sport federations and national
          committees.
        </p>

        <div class="statgrid">
          {stats.map((s) => (
            <div class="stat-block">
              <div class="k mono">{s.label}</div>
              <div class={`stat-value ${s.accent ? 'accent-text' : ''}`}>
                {s.href ? <a href={s.href} target="_blank" rel="noopener">{s.value}{s.unit}</a> : `${s.value}${s.unit}`}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="narrative">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">01</span><h2>Racing</h2></div>
      <div class="prose reveal">
        <p>
          I've raced internationally since 2005, with three Paralympic
          Games (London 2012, Rio 2016, Tokyo 2020) and World and
          European Championship selections throughout. My 100m personal
          best is 14.08 seconds.
        </p>
        <p>
          My best results include bronze in the 100m at the 2021 European
          Championships in Bydgoszcz, eighth at the 2023 World Championships in Paris,
          fifth at the 2024 World Championships in Kobe and seventh at the 2025 World Championships
          in New Delhi. I've been in the top 8 of the world since 2023 and staying there across separate championship cycles has been the better
          achievement than any single result.
        </p>
        <p>
          I train under Leo-Pekka Tähti, five-time Paralympic champion
          and the former 100m T54 world record holder. Racing at this level is all about continuous improvement.
          Right now we're aiming at my 100m time under 14.00 seconds and a
          medal place at the 2027 World Championships.
        </p>
      </div>
    </div>
  </section>

  <section class="narrative">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">02</span><h2>Off the track</h2></div>
      <div class="prose reveal">
        <p>
          I chair the Athletes' Commission of the Finnish Olympic
          Committee and sit on the Olympic Committee's board. The work is
          mostly structural: making athlete representation a substantive voice
          in decision-making rather than a formality. I helped build the
          Finnish Paralympic Committee's Athletes' Commission from the
          ground up and chaired it until autumn 2024. Today I hold board
          roles across Finnish sports and the disability sector,
          where an athlete's perspective and a business-and-economics
          lens meet institutional decisions.
        </p>
        <p>
          Earlier, I served as Secretary General of KY, the Association
          of Aalto University Business Students. In practice the role
          was executive director: responsibility for the office and the
          finances, nine employees, an annually elected board, and an
          annual budget over €500,000. It's where I learned that
          advocacy without operational credibility doesn't move
          anything.
        </p>
      </div>
    </div>
  </section>

  <section class="narrative">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">03</span><h2>Now</h2></div>
      <div class="prose reveal">
        <p>
          I'm completing a master's in Business Law with economics as a
          minor, and I do advisory work in wheelchair-related
          technology. Based in Espoo. I write, in Finnish and English,
          mostly about sport, governance, and the systems around both.
        </p>
      </div>
    </div>
  </section>

  <section class="roles">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">04</span><h2>Roles</h2></div>
      <ul class="role-list reveal">
        <li>Athlete: T54 100m, World Championship and Paralympic level</li>
        <li>Chairman, Athletes' Commission of Finnish Olympic Committee</li>
        <li>Board member, Finnish Olympic Committee (Suomen Olympiakomitea)</li>
        <li>Board member, Finnish Athletics Federation (Suomen Urheiluliitto)</li>
        <li>Board member, Athletes of Finland (Suomen Urheilijat ry)</li>
        <li>Vice chair, Abilis Foundation (Abilis-säätiö)</li>
        <li>Advisor, wheelchair and assistive technology, disability sector</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-hero {
    padding-top: clamp(140px, 20vh, 200px);
    padding-bottom: var(--space-4);
  }
  .profile-hero h1 {
    margin-top: var(--space-2);
  }
  .accent-text {
    color: var(--accent);
  }
  .profile-body {
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(32px, 6vw, 84px);
    align-items: start;
  }
  .bio p {
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    margin-bottom: var(--space-2);
    max-width: 36rem;
  }
  .bio p.lead {
    font-size: var(--text-lead);
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: none;
  }
  .bio .rule-accent {
    margin: var(--space-3) 0;
  }
  .statgrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    margin-top: var(--space-3);
    max-width: 28rem;
  }
  .stat-block {
    background: var(--bg);
    padding: 20px 20px 18px;
  }
  .narrative {
    border-top: 1px solid var(--rule);
  }
  .narrative .prose p {
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    margin-bottom: var(--space-2);
    max-width: 44rem;
  }
  .roles {
    border-top: 1px solid var(--rule);
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: var(--space-3);
  }
  .sec-head .idx {
    color: var(--accent);
    font-size: 0.75rem;
  }
  .role-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: var(--maxw);
  }
  .role-list li {
    padding: var(--space-1) 0 var(--space-1) var(--space-2);
    border-left: 2px solid var(--accent);
  }

  @media (max-width: 860px) {
    .profile-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .statgrid { grid-template-columns: 1fr; }
  }
</style>
