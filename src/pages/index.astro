---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoSlot from '../components/PhotoSlot.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { getCollection } from 'astro:content';
import { cleanSlug } from '../lib/slug';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Esa-Pekka Mattila" lang="en" description="Esa-Pekka Mattila — T54 wheelchair racer, 100m. Profile, results, and blog.">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-photo">
     <PhotoSlot src="/images/hero.jpg" alt="Esa-Pekka Mattila at the start line" placeholder="DROP A HERO PHOTO" showLabel={false} objectPosition="50% 22%" />
    </div>
    <div class="hero-inner wrap">
      <p class="kicker">Wheelchair Racing · 100m T54 · FIN</p>
      <h1 class="hero-name">Esa-Pekka<br /><span class="accent-text">Mattila.</span></h1>
      <div class="hero-meta">
        <span>CLASS <b>T54</b></span>
        <span>PB 100M <b>14.08s</b></span>
        <span>IG <b>@mattilae</b></span>
      </div>
    </div>
    <a class="photo-credit" href="https://tobil.ch/" target="_blank" rel="noopener">
      Photo <span>Tobias Lackner</span>
    </a>
    <div class="scrollcue" aria-hidden="true">
      <span class="mono">SCROLL</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- PROFILE PREVIEW -->
  <section id="profile-preview">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx mono">01</span><h2>Profile</h2></div>
      <div class="profile-grid">
        <div class="profile-photo reveal">
          <PhotoSlot src="/images/portrait.jpg" alt="Esa-Pekka Mattila" placeholder="DROP A PORTRAIT" aspect="4/5" />
        </div>
        <div class="bio reveal">
          <p class="lead">T54 wheelchair racer competing at World Championship and Paralympic level.</p>
          <div class="rule-accent"></div>
          <p>
            I race the 100m, T54 classification, based in Espoo. Off the
            track I chair the Athletes' Commission of the Finnish Olympic
            Committee and hold board roles across Finnish sport and the
            disability sector.
          </p>
          <div class="statgrid">
            <div class="stat-block"><div class="k mono">PB · 100m</div><div class="stat-value accent-text">14.08s</div></div>
            <div class="stat-block"><div class="k mono">Classification</div><div class="stat-value">T54</div></div>
            <div class="stat-block"><div class="k mono">Nationality</div><div class="stat-value">FIN</div></div>
            <div class="stat-block"><div class="k mono">Handle</div><div class="stat-value">@mattilae</div></div>
          </div>
          <a href="/profile" class="more">Full profile →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section id="blog-preview">
    <div class="wrap">
      <div class="sec-head blog-head reveal">
        <div class="idx-row"><span class="idx mono">02</span><h2>Blog</h2></div>
        <span class="mono">Writing &amp; photography</span>
      </div>

      {posts.length > 0 ? (
        <div class="posts">
          {posts.map((post) => (
            <a href={`/blog/${cleanSlug(post.slug)}`} class="post reveal">
              <div class="post-thumb">
             <PhotoSlot src={post.data.image} alt="" placeholder="POST IMAGE" aspect="16/10" />
                <CategoryBadge category={post.data.category} photo={post.data.photo} lang="en" variant="chip" />
              </div>
              <div class="post-body">
                <span class="mono post-date">{post.data.date.toISOString().slice(0, 10)}</span>
                <h3>{post.data.title}</h3>
                {post.data.summary && <p>{post.data.summary}</p>}
                <span class="more">Read →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="mono">No posts yet.</p>
      )}

      <p class="more all-posts"><a href="/blog">All posts →</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-photo :global(.photo-slot) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(14,13,12,0.55) 0%, rgba(14,13,12,0) 30%, rgba(14,13,12,0) 45%, rgba(14,13,12,0.78) 82%, rgba(14,13,12,1) 100%),
      linear-gradient(90deg, rgba(14,13,12,0.65) 0%, rgba(14,13,12,0) 55%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-bottom: clamp(64px, 12vh, 130px);
    padding-top: 140px;
  }
  .hero .kicker {
    margin-bottom: 22px;
  }
  .hero-name {
    font-size: var(--text-hero);
  }
  .accent-text {
    color: var(--accent);
  }
  .hero-name .accent-text {
    text-shadow: 0 4px 28px rgba(14, 13, 12, 0.75);
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 26px;
    margin-top: 30px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.09em;
    color: var(--muted);
  }
  .hero-meta b {
    color: var(--ink);
    font-weight: 500;
  }
  /* Photo credit sits on the opaque end of the hero gradient, so muted mono
     reads without extra scrim. Colour split (label muted, name in ink)
     mirrors .hero-meta. Generous padding is the tap target, not spacing —
     the visible text still lands on the scrollcue's baseline. */
  .photo-credit {
    position: absolute;
    right: var(--gutter);
    bottom: 12px;
    z-index: 3;
    padding: 14px 0 14px 16px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }
  .photo-credit span {
    color: var(--ink);
  }
  .photo-credit:hover,
  .photo-credit:hover span {
    color: var(--accent);
  }

  .scrollcue {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .scrollcue .mono {
    font-size: 0.625rem;
    letter-spacing: 0.12em;
  }
  .scrollcue .line {
    width: 1px;
    height: 34px;
    background: linear-gradient(var(--muted), transparent);
    animation: cue 1.8s ease-in-out infinite;
  }
  @keyframes cue {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ---- Section scaffolding ---- */
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 52px;
  }
  .sec-head .idx {
    color: var(--accent);
    font-size: 0.75rem;
  }
  #profile-preview {
    border-top: 1px solid var(--rule);
  }

  /* ---- Profile preview ---- */
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 6vw, 84px);
    align-items: start;
  }
  .bio p {
    font-size: clamp(1.0625rem, 1.5vw, 1.3125rem);
    margin-bottom: var(--space-2);
    max-width: 34rem;
  }
  .bio p.lead {
    font-size: var(--text-lead);
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: none;
  }
  .bio .rule-accent {
    margin: var(--space-3) 0;
  }
  .statgrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    margin: var(--space-2) 0 var(--space-3);
    max-width: 26rem;
  }
  .stat-block {
    background: var(--bg);
    padding: 20px 20px 18px;
  }
  .more {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ---- Blog preview ---- */
  #blog-preview {
    border-top: 1px solid var(--rule);
  }
  .blog-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .idx-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .post {
    background: var(--surface);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.22s ease, border-color 0.22s ease;
    color: var(--ink);
  }
  .post:hover {
    transform: translateY(-5px);
    border-color: rgba(226, 94, 31, 0.5);
  }
  .post-thumb {
    position: relative;
  }
  .post-body {
    padding: 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .post-body h3 {
    margin: 0;
  }
  .post-body p {
    font-size: 0.9375rem;
    color: var(--muted);
    flex: 1;
  }
  .post .more {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: gap 0.2s;
  }
  .post:hover .more {
    gap: 12px;
  }
  .all-posts {
    margin-top: var(--space-4);
  }

  @media (max-width: 860px) {
    .profile-grid { grid-template-columns: 1fr; }
    .posts { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .statgrid { grid-template-columns: 1fr; }
    .hero-meta { gap: 8px 18px; }
    /* Narrow enough that a right-aligned credit crowds the centred scroll
       cue, so move it to the gutter and let it sit under the hero copy. */
    .photo-credit {
      right: auto;
      left: var(--gutter);
      padding: 14px 16px 14px 0;
    }
  }
</style>
