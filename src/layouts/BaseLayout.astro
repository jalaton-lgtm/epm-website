---
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/inter-tight/600.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/tokens.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { localeAlternates } from '../lib/i18n';

export interface Props {
  title: string;
  description?: string;
  lang: 'en' | 'fi';
  /** Path to a social share image. Must be 1200x630 to match the
      og:image dimension tags below. Defaults to the site-wide image. */
  image?: string;
  /** Open Graph type — pass "article" on blog post pages. */
  type?: 'website' | 'article';
  /** ISO timestamp for article:published_time. Blog posts only. */
  publishedTime?: string;
  /** JSON-LD object (or objects) injected into the head as ld+json. */
  jsonLd?: object | object[];
}

const {
  title,
  description,
  lang,
  image = '/images/og-default.jpg',
  type = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

const siteName = 'Esa-Pekka Mattila';
const fullTitle = title === siteName ? siteName : `${title} — ${siteName}`;

// Canonical always points at the production domain (astro.config site),
// with a trailing slash to match Cloudflare's auto-trailing-slash
// handling. This also stops *.pages.dev from being indexed as the
// canonical copy once the domain is live.
const canonicalPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalURL = new URL(canonicalPath, Astro.site);
const imageURL = new URL(image, Astro.site);
const ogLocale = lang === 'fi' ? 'fi_FI' : 'en_US';

// hreflang alternates. localeAlternates returns absolute paths for both
// languages, or null where there is no honest pair (404, or an untranslated
// post). Trailing slash matches the canonical form above. x-default points at
// the English version per the plan.
const withSlash = (p: string) => (p.endsWith('/') ? p : `${p}/`);
const alternates = localeAlternates(Astro.url.pathname, lang);
const altLinks = alternates
  ? [
      { hreflang: 'en', href: new URL(withSlash(alternates.en), Astro.site) },
      { hreflang: 'fi', href: new URL(withSlash(alternates.fi), Astro.site) },
      { hreflang: 'x-default', href: new URL(withSlash(alternates.en), Astro.site) },
    ]
  : [];

// Cloudflare Web Analytics — paste the site token from the Cloudflare
// dashboard (Analytics & Logs -> Web Analytics -> Add a site). The
// beacon script is only rendered when a token is present, so an empty
// string here ships nothing.
const CF_ANALYTICS_TOKEN = '12a75a1d8d8241a389a2eb8c79df9472';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0E0D0C" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Esa-Pekka Mattila"
      href={lang === 'fi' ? '/fi/rss.xml' : '/rss.xml'}
    />
    {altLinks.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={imageURL} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {CF_ANALYTICS_TOKEN && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${CF_ANALYTICS_TOKEN}"}`}
      ></script>
    )}
  </head>
  <body>
    <span id="top"></span>
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style is:global>
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s cubic-bezier(.2, .7, .2, 1), transform 0.7s cubic-bezier(.2, .7, .2, 1);
    }
    .reveal.in {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
