---
import Hud from './Hud.astro';
import { canonicalPathOf, otherLangOf, twinOf, type Lang } from '../lib/i18n';

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const otherLang = otherLangOf(lang);
const otherLangPath = twinOf(canonicalPathOf(Astro.url.pathname, lang), lang);

const nav = {
  en: [
    { href: '/', label: 'Home' },
    { href: '/profile', label: 'Profile' },
    { href: '/blog', label: 'Blog' },
    { href: '/partners', label: 'Partners' },
  ],
  fi: [
    { href: '/fi/', label: 'Etusivu' },
    { href: '/fi/profile', label: 'Profiili' },
    { href: '/fi/blog', label: 'Blogi' },
    { href: '/fi/partners', label: 'Kumppanit' },
  ],
};
---

<header class="nav" id="site-nav">
  <a href={lang === 'en' ? '/' : '/fi/'} class="brandmark">EPM</a>
  <button class="navtoggle" id="navtoggle" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
  <nav class="links" id="navlinks" aria-label="Primary">
    {nav[lang].map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
    <a href={otherLangPath} class="lang-switch" hreflang={otherLang}>
      {lang === 'en' ? 'FI' : 'EN'}
    </a>
    <a href="mailto:ep@esapekkamattila.com" class="cta">{lang === 'en' ? 'Contact' : 'Yhteystiedot'}</a>
    <Hud />
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px var(--gutter);
    border-bottom: 1px solid transparent;
    transition: background 0.3s, border-color 0.3s, padding 0.3s;
  }
  .nav.scrolled {
    background: rgba(14, 13, 12, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--rule);
    padding-block: 13px;
  }
  .brandmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .links {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.09em;
    color: var(--muted);
    text-transform: uppercase;
    padding: 8px 14px;
  }
  .links a:hover {
    color: var(--ink);
  }
  .links a.cta {
    color: var(--accent);
    border: 1px solid var(--accent);
  }
  .links a.cta:hover {
    background: var(--accent);
    color: #fff;
  }
  .navtoggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    /* 12px padding around the 22px bar stack makes the button 46x46. At the
       previous 8px it measured 38x38 — past WCAG 2.5.8 (24px) but under the
       44px touch guideline, and it is the one control a phone user cannot
       avoid. */
    padding: 12px;
  }
  .navtoggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    margin: 4px 0;
    transition: 0.2s;
  }

  @media (max-width: 860px) {
    .links {
      position: fixed;
      inset: 0 0 0 auto;
      width: min(78vw, 320px);
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 4px;
      background: var(--surface);
      padding: 40px;
      transform: translateX(100%);
      /* The slide alone parks the links off-screen but leaves them in the tab
         order — six invisible tab stops, confirmed with real Tab presses at
         375px. visibility removes them from it; the 0.3s delay lets the slide
         finish before it takes effect, so the animation is unchanged. */
      visibility: hidden;
      transition: transform 0.3s, visibility 0s linear 0.3s;
      z-index: 99;
    }
    .links.open {
      transform: none;
      visibility: visible;
      transition: transform 0.3s, visibility 0s;
    }
    .links a {
      font-size: 0.9375rem;
      padding: 12px 0;
    }
    .navtoggle {
      display: block;
    }
    .navtoggle.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .navtoggle.open span:nth-child(2) { opacity: 0; }
    .navtoggle.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  }

  /* The global reduced-motion rule shortens transition-duration but not
     transition-delay, which would leave the closed drawer focusable for
     0.3s. Drop the delay too — with no slide to wait for, there is nothing
     for it to protect. */
  @media (max-width: 860px) and (prefers-reduced-motion: reduce) {
    .links {
      transition-delay: 0s;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 40);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.getElementById('navtoggle');
  const links = document.getElementById('navlinks');
  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    toggle.classList.toggle('open', !!open);
    toggle.setAttribute('aria-expanded', String(!!open));
  });
  links?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle?.classList.remove('open');
    })
  );
</script>
