---
export interface Props {
  lang: 'en' | 'fi';
}
const { lang } = Astro.props;
const year = new Date().getFullYear();
// The three big words link to their destination once that destination
// exists. href: null renders plain text on purpose — the footer should
// never point at a page that hasn't shipped. All three have now landed.
const copy = {
  en: {
    words: [
      { text: 'Sponsorship,', href: '/partners' },
      { text: 'speaking,', href: '/partners#speaking' },
      { text: 'press', href: '/press' },
    ],
    sub: 'Open to partners through LA28.',
    backTop: 'Back to top ↑',
    identity: 'Esa-Pekka Mattila · Wheelchair Racing · FIN',
  },
  fi: {
    words: [
      { text: 'Sponsorointi,', href: '/fi/partners' },
      { text: 'puheenvuorot,', href: '/fi/partners#speaking' },
      { text: 'media', href: '/fi/press' },
    ],
    sub: 'Kumppanuudet avoinna LA28:aan asti.',
    backTop: 'Ylös ↑',
    identity: 'Esa-Pekka Mattila · Pyörätuolikelaus · FIN',
  },
};
const c = copy[lang];
---
<footer class="site-footer">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-cta reveal">
        <div class="foot-mono">{c.words.map((w, i) => (
          <Fragment>
            {i > 0 && <br />}
            {w.href ? <a href={w.href}>{w.text}</a> : w.text}
          </Fragment>
        ))}<span class="dot">.</span></div>
        <p class="foot-sub">{c.sub}</p>
      </div>
      <div class="foot-links reveal">
        <a href="mailto:ep@esapekkamattila.com">ep@esapekkamattila.com</a>
        <a href="https://instagram.com/mattilae" target="_blank" rel="noopener me">Instagram · @mattilae</a>
        <a href="https://x.com/epmattila" target="_blank" rel="noopener me">X · @epmattila</a>
        <a href="#top" class="back">{c.backTop}</a>
      </div>
    </div>
    <div class="foot-base">
      <span>{c.identity}</span>
      <span>&copy; {year} EPM</span>
    </div>
  </div>
</footer>
<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    padding-block: var(--space-6);
  }
  .foot-grid {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .foot-mono {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 5.5vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-transform: uppercase;
  }
  .foot-mono .dot {
    color: var(--accent);
  }
  /* Global `a` is accent-coloured; the big words should stay ink and pick
     up the accent on hover, matching .foot-links below. */
  .foot-mono a {
    color: inherit;
  }
  .foot-mono a:hover {
    color: var(--accent);
  }
  .foot-sub {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .foot-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
    text-align: right;
  }
  .foot-links a {
    color: var(--muted);
  }
  .foot-links a:hover {
    color: var(--accent);
  }
  .foot-base {
    margin-top: var(--space-4);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
  }
</style>
