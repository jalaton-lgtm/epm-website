---
export interface Props {
  src?: string;
  alt?: string;
  placeholder: string; // shown when no src provided, e.g. "DROP A HERO PHOTO"
  aspect?: string; // CSS aspect-ratio value, e.g. "4/5", "16/10"
  showLabel?: boolean; // false hides the visible text hint — use where large
                        // overlapping content (e.g. hero headline) would
                        // collide with a centered label; the diagonal
                        // stripe pattern alone still reads as an
                        // intentional dark texture rather than "missing"
  objectPosition?: string; // CSS object-position, default "50% 50%" (center).
                            // Lower Y values (e.g. "50% 25%") show more of
                            // the top of the source image — useful when a
                            // subject's head is getting cropped off.
}
const { src, alt = '', placeholder, aspect, showLabel = true, objectPosition = '50% 50%' } = Astro.props;
---

<div class="photo-slot" style={aspect ? `aspect-ratio: ${aspect};` : ''}>
  {src ? (
    <img src={src} alt={alt} style={`object-position: ${objectPosition};`} />
  ) : (
    <div class="stripe" role="img" aria-label={placeholder}>
      {showLabel && <span class="mono">{placeholder}</span>}
    </div>
  )}
</div>

<style>
  .photo-slot {
    position: relative;
    overflow: hidden;
    background: var(--surface);
  }
  .photo-slot img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .stripe {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      135deg,
      var(--placeholder-a) 0 14px,
      var(--placeholder-b) 14px 28px
    );
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-2);
  }
  .stripe .mono {
    color: rgba(244, 241, 236, 0.55);
    background: rgba(14, 13, 12, 0.55);
    padding: 0.4em 0.8em;
  }
</style>
